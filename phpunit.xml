<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://w3.org"
         xsi:noNamespaceSchemaLocation="https://phpunit.de"
         bootstrap="Tests/boot.php"
         displayDetailsOnTestsThatTriggerNotices="false"
         displayDetailsOnTestsThatTriggerWarnings="false">

    <source restrictNotices="false" restrictWarnings="false">
        <include>
            <directory suffix=".php">./Source</directory>
        </include>
    </source>

    <testsuites>
        <testsuite name="Squid">
            <directory>Tests/Squid</directory>
        </testsuite>
    </testsuites>
    <coverage>
        <report>
            <clover outputFile="build/logs/clover.xml"/>
        </report>
    </coverage>
</phpunit>
